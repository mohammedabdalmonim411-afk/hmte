# ============================================
# Phase Control Runtime Files
# ============================================
# Root-level runtime (complete coverage)
.phase_control/
.phase_control_archive/

# Dev and validation artifacts (top-level ignore)
dev/
private_validation/

# Dev runtime (legacy rules - covered by top-level dev/)
dev/.phase_control/
dev/.phase_control_archive/
dev/.hmte/

# Dogfood / regression test artifacts (never commit)
dogfood_regression/
dogfood_regression_round*/
dev/dogfood/

# Keep directory structure
!dev/.phase_control/evidence/.gitkeep
!dev/.phase_control/verdicts/.gitkeep
!dev/.phase_control/logs/.gitkeep
!dev/.phase_control/pids/.gitkeep
!dev/.phase_control/traces/.gitkeep

